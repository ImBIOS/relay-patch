{
  "name": "relay-patch",
  "version": "0.2.8",
  "description": "Keep up-to-date upstream + your custom patches. Patches are intent, not diffs.",
  "module": "src/cli.ts",
  "type": "module",
  "bin": {
    "relay-patch": "./bin/relay-patch.js"
  },
  "files": [
    "bin",
    "src",
    "index.ts",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "Dockerfile",
    "test-orchestrator.sh",
    ".opencode"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "build:binaries": "bash scripts/build-binaries.sh",
    "start": "bun run src/cli.ts",
    "init": "bun run src/cli.ts init",
    "draft": "bun run src/cli.ts draft",
    "satisfied": "bun run src/cli.ts satisfied",
    "import": "bun run src/cli.ts import",
    "search": "bun run src/cli.ts search",
    "re-derive": "bun run src/cli.ts re-derive",
    "apply": "bun run src/cli.ts apply",
    "drift-check": "bun run src/cli.ts drift-check",
    "watch": "bun run src/cli.ts watch",
    "update": "bun run src/cli.ts update",
    "rollback": "bun run src/cli.ts rollback",
    "status": "bun run src/cli.ts status",
    "prepublishOnly": "tsc --noEmit"
  },
  "keywords": [
    "git",
    "fork",
    "patch",
    "ai",
    "opencode",
    "intent",
    "upstream",
    "rebase",
    "merge"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ImBIOS/relay-patch.git"
  },
  "bugs": {
    "url": "https://github.com/ImBIOS/relay-patch/issues"
  },
  "homepage": "https://github.com/ImBIOS/relay-patch#readme",
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
